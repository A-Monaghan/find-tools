# RAG-v2.1 Frontend
# Copy to .env and adjust as needed.

# Backend API (prod/Fly or Northflank: public URL of the API service, no trailing slash)
# VITE_API_BASE_URL=https://rag-backend.fly.dev
# VITE_API_BASE_URL=https://your-api-service.northflank.app

# Entity Extractor backend (OOCP - default: /ee proxy to localhost:5001 in dev)
# VITE_ENTITY_EXTRACTOR_URL=http://localhost:5001
