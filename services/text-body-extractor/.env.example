# Environment variables for Text Body Relationship Extractor
# Copy this file to .env and fill in your actual API keys
#
# Port: FIND Tools Vite dev proxies /ee → http://localhost:5001 (avoid macOS AirPlay on 5000).
PORT=5001

# OpenRouter API (recommended - supports multiple models via one API)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
# Performance tuning:
# - false = single-pass extraction (faster), true = two-pass extraction (higher quality)
TWO_PASS_DEFAULT=false
# Cap chunk-level LLM calls per request (lower = faster).
MAX_CHUNKS=4
# Disable Docling chunker for lower CPU/memory usage in local dev.
DOCLING_ENABLED=false

# Gemini API (Google AI)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Ollama Configuration (for local LLMs)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_OLLAMA_MODEL=llama3.2

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Neo4j (for Push to Neo4j - ingest entities/relationships into graph)
# Local: bolt://localhost:7687 | Fly: bolt://neo4j.internal:7687
# Aura: neo4j+s://xxxx.databases.neo4j.io (or use UI connection in Entity Extractor)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
