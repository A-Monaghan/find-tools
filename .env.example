# ============================================
# RAG-v2.1 Configuration
# ============================================

# === SERVER ===
# Backend API port (frontend proxies /api to this)
PORT=8010

# === OPERATION MODE ===
# "private" = local only (vLLM + local embeddings)
# "hybrid" = prefer local, fallback to cloud
# "cloud" = cloud only (OpenRouter + OpenAI embeddings)
OPERATION_MODE=hybrid

# === DATABASE ===
DB_PASSWORD=changeme
# When running the API on the host (venv + ./scripts/run_backend_venv.sh), use 127.0.0.1 — not `postgres` (Docker-only).
# DATABASE_URL=postgresql+asyncpg://raguser:changeme@127.0.0.1:5432/ragdb

# === VECTOR STORE ===
VECTOR_STORE_TYPE=qdrant

# === LOCAL LLM (vLLM) ===
VLLM_URL=http://localhost:8000/v1

# === CLOUD LLM (OpenRouter) ===
OPENROUTER_API_KEY=sk-or-v1-...
# OpenRouter model id for Draft / fast pass in the UI (cheap mini models work well)
OPENROUTER_FAST_MODEL=openai/gpt-4o-mini

# === EMBEDDINGS ===
OPENAI_API_KEY=sk-...

# === NEO4J (Aura or local) ===
# For Neo4j Aura: use the connection URI from your Aura console (neo4j+s://...)
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-aura-password
# For local Neo4j in Docker: NEO4J_URI=bolt://neo4j:7687 (and uncomment neo4j service in docker-compose)

# === NAME SCREENING (OpenSanctions / Aleph / Sayari) — optional; server-side only ===
# OPENSANCTIONS_API_KEY=
# ALEPH_API_KEY=
# ALEPH_API_BASE=https://aleph.occrp.org/api/2
# SAYARI_CLIENT_ID=
# SAYARI_CLIENT_SECRET=
# SAYARI_API_BASE=https://api.sayari.com

# === COMPANIES HOUSE ===
# COMPANIES_HOUSE_API_KEY=your-key-from-developer.company-information.service.gov.uk
# CH_JOB_EXPIRY_HOURS=0  # 0 = manual delete only; set >0 for auto-cleanup after N hours

# === CROSS-SERVICE (Entity Extractor) ===
# When RAG backend runs in Docker, use host.docker.internal to reach OOCP on host
# Use 5001 if macOS AirPlay occupies 5000
ENTITY_EXTRACTOR_URL=http://host.docker.internal:5001

# === ADVANCED RAG FEATURES ===
# Docling: multi-format parsing (PDF, DOCX, PPTX, XLSX, HTML, images)
ENABLE_DOCLING=true
# Chunking strategy: auto, sections, paragraphs, sliding, semantic
CHUNKING_STRATEGY=auto
# Fusion retrieval: combine BM25 sparse + dense vector search
ENABLE_FUSION_RETRIEVAL=true
FUSION_ALPHA=0.5
# HyDE: hypothetical document embedding for short/vague queries
ENABLE_HYDE=true
# Corrective RAG: self-check retrieval quality + web fallback
ENABLE_CORRECTIVE_RAG=true
# Cross-encoder rerank (sentence-transformers on CPU) — accurate but slow; set false for snappier chat
ENABLE_CROSS_ENCODER_RERANK=true
# One flag: disables HyDE, fusion, CRAG, and cross-encoder rerank (fastest discussion / chat turns)
RAG_LOW_LATENCY=false

# === STABILITY PROFILES ===
# custom: keep manual toggles above
# stability_safe: conservative deterministic mode (lower variance)
# stability_full: stable full RAG path (all core features enabled)
RUNTIME_STABILITY_PROFILE=custom

# Profile presets (copy these values when needed):
# stability_safe: ENABLE_HYDE=false, ENABLE_FUSION_RETRIEVAL=false,
#   ENABLE_CORRECTIVE_RAG=false, ENABLE_CROSS_ENCODER_RERANK=false, TOP_K_VECTOR_SEARCH=12
# stability_full: ENABLE_HYDE=true, ENABLE_FUSION_RETRIEVAL=true,
#   ENABLE_CORRECTIVE_RAG=true, ENABLE_CROSS_ENCODER_RERANK=true, TOP_K_VECTOR_SEARCH=20
